# Database Connection Strings
# Copy this file to .env.local and fill in your actual values from Vercel
# NEVER commit .env.local to git

# Primary Prisma database URL (used by Prisma ORM)
PRISMA_DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Alternative PostgreSQL URL (can be used by other tools)
POSTGRES_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Backup/fallback URL
PRISMA_DATABASE_URL_BACKUP="postgresql://user:password@host:5432/database?sslmode=require"
